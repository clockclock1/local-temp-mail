JWT_SECRET=replace-this-secret
PREFIX=tmp
DEFAULT_LANG=zh

DEFAULT_DOMAINS=["example.com"]
DOMAINS=["example.com"]
ENABLE_CREATE_ADDRESS_SUBDOMAIN_MATCH=true
RANDOM_SUBDOMAIN_DOMAINS=["example.com"]
RANDOM_SUBDOMAIN_LENGTH=8

ENABLE_USER_CREATE_EMAIL=true
ENABLE_USER_DELETE_EMAIL=true
ENABLE_ADDRESS_PASSWORD=true
DISABLE_ADMIN_PASSWORD_CHECK=false
PASSWORDS=[]
ADMIN_PASSWORDS=["admin-password"]

LOCAL_HTTP_PORT=8787
LOCAL_SMTP_PORT=2525

# Optional outbound SMTP for SEND_MAIL binding emulation
# LOCAL_SENDMAIL_HOST=127.0.0.1
# LOCAL_SENDMAIL_PORT=25
# LOCAL_SENDMAIL_SECURE=false
# LOCAL_SENDMAIL_USER=
# LOCAL_SENDMAIL_PASS=

# Optional SMTP provider config for /api/send_mail
# SMTP_CONFIG={"example.com":{"host":"127.0.0.1","port":25,"secure":false}}
